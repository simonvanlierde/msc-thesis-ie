{
  "name": "cooling-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive dashboard for the MSc thesis cooling-demand & LCA model of The Hague.",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm lint && pnpm test:coverage && pnpm build",
    "data": "python scripts/build_scenarios.py && python scripts/build_choropleth.py && python scripts/build_temporal.py",
    "og": "node scripts/build_og.mjs"
  },
  "dependencies": {
    "@nivo/line": "^0.99.0",
    "maplibre-gl": "^5.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
